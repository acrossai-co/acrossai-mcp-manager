<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         beStrictAboutOutputDuringTests="true"
         beStrictAboutTestsThatDoNotTestAnything="true"
         failOnRisky="true"
         failOnWarning="true"
         cacheDirectory=".phpunit.cache">

    <testsuites>
        <!--
            MCPClients: pure service classes — tests MUST run without WP
            bootstrap (SC-003). This suite is the canonical proof of
            FR-008 architectural purity.
        -->
        <testsuite name="mcpclients">
            <directory>tests/phpunit/MCPClients</directory>
        </testsuite>

        <!--
            CLI REST (Phase 6): tests need WP for transients, nonces,
            wp_set_current_user, register_rest_route, WP_Application_Passwords.
            Reuses Phase 5.0 bootstrap-wp.php (no new harness work). Covers
            includes/REST/ + public/Partials/ + includes/Database/CliAuthLog/Recorder.
        -->
        <testsuite name="cli-rest">
            <directory>tests/phpunit/RestCli</directory>
            <directory>tests/phpunit/FrontendAuth</directory>
        </testsuite>

        <!--
            Admin (Feature 012 + Feature 013): tests need WP for register_setting,
            $wp_registered_settings, WP_UnitTestCase. Run with
            the bootstrap tests/bootstrap-wp.php. Recursively covers subdirectories
            including tests/phpunit/Admin/ServerTabs/ added by Feature 013.
            Extended by Feature 015 to also cover tests/phpunit/Includes/AccessControl/.
        -->
        <testsuite name="admin">
            <directory>tests/phpunit/Admin</directory>
            <directory>tests/phpunit/Includes/AccessControl</directory>
        </testsuite>

        <!--
            Renderers (Feature 013): tests for public/Renderers/ layer + REST
            controller. Need WP for get_option, current_user_can,
            wp_create_nonce, WP_Application_Passwords. Run with
            the bootstrap tests/bootstrap-wp.php.
        -->
        <testsuite name="renderers">
            <directory>tests/phpunit/Public/Renderers</directory>
        </testsuite>

        <!--
            OAuth (Feature 021): tests for the OAuth 2.1 authorization server.
            All tests extend OAuthTestCase which truncates the 3 F021 tables +
            resets ConnectorProfileRegistry memoization before each test.
            Requires WP (wp_generate_uuid4, wp_delete_user, rest_do_request,
            wp_schedule_event) — use tests/bootstrap-wp.php.

            Coverage: BerlinDB phantom guard + column widths + atomic CAS +
            PKCE S256 + RateLimiter + SecretsVault + ConnectorRegistry +
            TokenValidator (recursion + audience + no-header short-circuit +
            bearer fallbacks) + UserLifecycle cascade + DCR + Admin
            credential generation + Discovery metadata + SEC-021-001 refresh
            family revocation + Uninstall opt-in gate.
        -->
        <testsuite name="oauth">
            <directory>tests/phpunit/OAuth</directory>
        </testsuite>

        <!--
            Abilities (Feature 017/F026/F030): tests for the WP Abilities API
            integration layer under includes/Abilities/. Covers CallbackReplacer,
            CurrentServerHolder, Discover/Execute/GetAbilityInfo, and
            PermissionOverrideProcessor (F030). Requires WP for
            wp_get_ability, wp_register_ability_args filter dispatch,
            rest_pre_dispatch — use tests/bootstrap-wp.php.
        -->
        <testsuite name="abilities">
            <directory>tests/phpunit/Abilities</directory>
        </testsuite>

        <!--
            Database (Feature 011/F017/F025/F029/F030): tests for BerlinDB
            Schema/Table/Row/Query subclasses + upgrade callbacks + phantom-
            version guard. Requires WP for $wpdb, INFORMATION_SCHEMA reads,
            get_option / update_option — use tests/bootstrap-wp.php.
        -->
        <testsuite name="database">
            <directory>tests/phpunit/Database</directory>
        </testsuite>

        <!--
            MCP (Feature 017/F020/F025/F026): tests for the MCP boundary layer
            under includes/MCP/ — enforcement gates on mcp_adapter_pre_tool_call
            (F015 access control, F017 ability exposure, F020 tool curation).
            Requires WP for filter dispatch — use tests/bootstrap-wp.php.
        -->
        <testsuite name="mcp">
            <directory>tests/phpunit/MCP</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory>includes</directory>
        </include>
        <exclude>
            <directory>includes/Database</directory><!-- WP-dependent; not in 004 scope -->
        </exclude>
    </source>
</phpunit>
